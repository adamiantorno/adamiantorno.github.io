<div id="footer">
    <div class="container footer-body">
        <div class="footer-contact">
            <p class="footer-text">Want to chat? Get in touch with me below.</p>
            <div class="link-container">
                <a 
                    class="underline-link contact-link" 
                    target="_blank" 
                    rel="noreferrer noopener" 
                    href="https://github.com/adamiantorno">@Github</a>
                <a 
                    class="underline-link contact-link" 
                    target="_blank" 
                    rel="noreferrer noopener" 
                    href="https://www.linkedin.com/in/adamiantorno/">@LinkedIn</a>
            </div>
            <div class="link-container">
                <button class="contact-btn-link" id="email-btn-footer">Email: 
                    <span class="underline-link email-tag">adam [dot] iantorno [at] gmail [dot] com</span>
                </button>
            </div>
        </div>
        <div class="footer-copy">
            <span>&copy; Copyright 2026.</span>
            <span>Website developped by Adam Iantorno</span>
            <a class="return-link" href="#home">Back to top</a>
        </div>
    </div>
</div>

<style>
    
    #footer {
        margin-top: 4.8rem;
        padding: 1.6rem 1.2rem;
        background: rgba(0, 0, 0, 0.75);
        border-top: 1px solid rgba(255,255,255,0.06);
        --link-color-1: #c6bbe2;
    }

    .container {
        max-width: 960px;
        margin: 0 auto;
        width: 100%;
    }

    .footer-body {
        display: -webkit-box;
        display: -ms-flexbox;
        display: flex;
        -webkit-box-orient: horizontal;
        -webkit-box-direction: normal;
        -ms-flex-direction: row;
        flex-direction: row;
        -webkit-box-pack: justify;
        -ms-flex-pack: justify;
        justify-content: space-between;
        gap: 3rem;
        -ms-flex-wrap: wrap;
        flex-wrap: wrap;
        margin: 0 auto;
    }

    .footer-contact {
        display: -webkit-box;
        display: -ms-flexbox;
        display: flex;
        -webkit-box-orient: vertical;
        -webkit-box-direction: normal;
        -ms-flex-direction: column;
        flex-direction: column;
        gap: 1rem;
    }

    .footer-copy {
        display: -webkit-box;
        display: -ms-flexbox;
        display: flex;
        
        -webkit-box-orient: vertical;
        -webkit-box-direction: normal;
            -ms-flex-direction: column;
        flex-direction: column;
        

        gap: 0.5rem;
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.6);
        text-align: right;
    }

    .footer-text, .contact-btn-link {
        font-size: 1.1rem;
        font-weight: 500;
        color: #fefefe;
    }

    .link-container {
        display: -webkit-box;
        display: -ms-flexbox;
        display: flex;
        gap: 1.5rem;
        -ms-flex-wrap: wrap;
        flex-wrap: wrap;
    }

    .contact-link {
        font-size: 1rem;
        font-style: italic;
        color: var(--color-primary-light);
    }

    .contact-link:hover {
        color: var(--color-contrast);
    }

    .contact-link:before {
        background-color: var(--color-contrast) !important;
    }

    .contact-btn-link {
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        font-size: 1rem;
    }

    .email-tag {
        font-size: 1rem;
        font-weight: bold;
        color: var(--color-primary-light);
    }
    
    .email-tag:hover {
        color: var(--color-contrast);
    }

    .email-tag:before {
        background-color: var(--color-contrast) !important;
    }

    .return-link {
        color: var(--link-color-1);
    }

    @media (max-width: 1024px) {
        .footer-text, .contact-btn-link {
            font-size: 0.9rem;
        }

        .footer-contact,
        .footer-copy {
            width: 100%;
            text-align: left;
        }
    }


    @media (max-width: 640px) {
        .footer-body {
            -webkit-box-orient: vertical;
            -webkit-box-direction: normal;
            -ms-flex-direction: column;
            flex-direction: column;
            gap: 2rem;
        }

        .footer-copy {
            text-align: left;
        }

        .footer-text, .contact-btn-link {
            font-size: 0.8rem;
        }

        .contact-link, .email-tag, .contact-btn-link {
            font-size: 0.8rem;
        }
    }

    #snackbar {
        visibility: hidden;
        min-width: 275px;
        margin-left: -125px;
        background-color: rgba(0, 0, 0, 0.5);
        -webkit-backdrop-filter: blur(10px);
        backdrop-filter: blur(10px);
        color: #fefefe;
        text-align: center;
        border-radius: 2px;
        padding: 16px;
        position: fixed;
        z-index: 5;
        left: 50%;
        bottom: 50px;
    }

    #snackbar.show {
        visibility: visible;
        -webkit-animation: fadein 0.5s, fadeout 0.5s 2.5s;
        animation: fadein 0.5s, fadeout 0.5s 2.5s;
    }

    /* Animations to fade the snackbar in and out */
    @-webkit-keyframes fadein {
        from {bottom: 0; opacity: 0;}
        to {bottom: 50px; opacity: 1;}
    }

    @keyframes fadein {
        from {bottom: 0; opacity: 0;}
        to {bottom: 50px; opacity: 1;}
    }

    @-webkit-keyframes fadeout {
        from {bottom: 50px; opacity: 1;}
        to {bottom: 0; opacity: 0;}
    }

    @keyframes fadeout {
        from {bottom: 50px; opacity: 1;}
        to {bottom: 0; opacity: 0;}
    }

</style>

<script>

    const email: string = "adam.iantorno99@gmail.com";
    const button = document.getElementById("email-btn-footer");
    const snackbar = document.getElementById("snackbar") as HTMLElement;

    button?.addEventListener('click', () => {
        // Copy the text inside the text field
        navigator.clipboard.writeText(email);
        snackbar.className = "show";

        // After 3 seconds, remove the show class from DIV
        setTimeout(function() {
            snackbar.className = snackbar.className.replace("show", ""); 
        }, 3000)
    })

</script>